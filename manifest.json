{
  "name": "revEel",
  "description": "Base Level Extension",
  "version": "1.0",
  "manifest_version": 3,
  "permissions": ["activeTab", "scripting", "sidePanel"],
  "host_permissions": ["<all_urls>"],

  "background": {
      "service_worker": "worker.js"
  },

  "action": {},

  "side_panel": {
    "default_path": "reveel.html"
  },

  "icons": {
    "16": "images/16.png",
    "32": "images/32.png",
    "48": "images/48.png",
    "64": "images/64.png",
    "128": "images/128.png"
  }
}